{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"verbatimModuleSyntax": true,
		"paths": {
			"layouts/*": ["./src/layouts/*"],
			"core/*": ["./src/components/core/*"],
			"shared/*": ["./src/components/shared/*"]
		},
		"plugins": [
			{
				"name": "@astrojs/ts-plugin"
			}
		]
	}
}
